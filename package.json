{
  "name": "ai-creative-editor",
  "version": "1.0.0",
  "description": "AI-powered creative editor with Canvas and Templater plugins, works offline like Obsidian",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [
    "electron",
    "editor",
    "ai",
    "markdown",
    "canvas",
    "templater"
  ],
  "author": "AI Creative Editor Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "codemirror": "^6.0.1",
    "@codemirror/lang-markdown": "^6.2.4",
    "@codemirror/view": "^6.23.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/commands": "^6.3.3",
    "@codemirror/language": "^6.10.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "konva": "^9.3.0",
    "marked": "^11.1.1",
    "axios": "^1.6.5"
  },
  "build": {
    "appId": "com.aicreativeeditor.app",
    "productName": "AI Creative Editor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/*.ts",
      "!*.map"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}

